{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["@webgpu/types", "node"],
    "paths": {
      "solid-js": ["./node_modules/solid-js"],
      "solid-js/*": ["./node_modules/solid-js/*"],
      "@omnidea/net": ["../../Library/sdk/src/index.ts"],
      "@omnidea/ui": ["../../Library/ui/src/lib/index.ts"],
      "@omnidea/ui/*": ["../../Library/ui/src/lib/*"],
      "@omnidea/crystal": ["../../Library/crystal/src/index.ts"],
      "@omnidea/editor": ["../../Library/editor/src/index.ts"],
      "@omnidea/fx": ["../../Library/fx/src/lib/index.ts"],
      "@castle/cornerstone": ["../cornerstone/index.ts"],
      "@vizier": ["../vizier/index.ts"]
    }
  },
  "include": [
    "src",
    "../court",
    "../cornerstone",
    "../crownsguard",
    "../sceptor",
    "../attendants",
    "../vizier",
    "../../Library/crystal/src/env.d.ts"
  ]
}
